# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude
.claude/

# Heavy HDR environment assets — keep them out of the repo. We load them
# at runtime from public/hdri/*.exr and *.hdr; the files themselves get
# dropped in manually (locally, or fetched by an admin). Committing a
# 4K EXR (~70MB) permanently bloats the repo history. When shipping
# for production, use a 1K/2K .hdr version from Poly Haven.
public/hdri/*.exr
public/hdri/*.hdr
