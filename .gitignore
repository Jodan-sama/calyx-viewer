# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude
.claude/

# Heavy HDR environment assets — keep 4K+ EXRs out of the repo. Smaller
# 1K/2K .hdr files (~1-10MB each) are fine to commit; we load them at
# runtime from public/hdri. Poly Haven is the canonical source.
public/hdri/*.exr
